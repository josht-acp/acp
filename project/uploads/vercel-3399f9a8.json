{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/portal", "destination": "/portal.html" },
    { "source": "/portal/:path*", "destination": "/portal.html" },
    { "source": "/client-portal", "destination": "/client-portal.html" },
    { "source": "/internal-portal", "destination": "/internal-portal.html" },
    { "source": "/internal", "destination": "/internal-portal.html" },
    { "source": "/ir", "destination": "/ir.html" },
    { "source": "/ir/:path*", "destination": "/ir.html" },
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/docs/:path*", "destination": "/docs.html" },
    { "source": "/ops", "destination": "/ops.html" },
    { "source": "/ops/:path*", "destination": "/ops.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/(ops|internal-portal|internal)(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
